{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "sortPackageJson": false,
  "ignorePatterns": [
    "package-lock.json",
    "pnpm-lock.yaml",
    "**/CHANGELOG.md",
    "AGENTS.md",
    "CLAUDE.md",
    "node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.turbo/**",
    "apps/website/rspress.config.ts",
    "apps/website/doc_build/**",
    "apps/website/docs/**",
    "packages/vseed/tests/**/*.ts",
    // Stencil auto-generated files
    "packages/vbi-component/src/**/*.md",
    "packages/vbi-component/src/components.d.ts"
  ]
}
