{
  "name": "vbi_cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "vbi": "./dist/cli.js"
  },
  "scripts": {
    "build": "pnpm --filter=@visactor/vbi-provider run build && tsc -p tsconfig.build.json",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@visactor/vbi-provider": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "9.39.0",
    "@types/node": "24.10.1",
    "eslint": "9.39.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "3.2.4"
  }
}
