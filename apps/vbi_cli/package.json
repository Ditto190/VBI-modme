{
  "name": "@visactor/headless-bi-cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "vbi": "./dist/cli.js"
  },
  "scripts": {
    "build": "pnpm --filter=@visactor/vbi-agent run build && pnpm --filter=@visactor/headless-bi-provider run build && rslib build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@visactor/vbi-agent": "workspace:*",
    "@visactor/headless-bi-provider": "workspace:*",
    "dotenv": "17.2.1",
    "ink": "7.0.1",
    "react": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.0",
    "@rslib/core": "0.20.3",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "eslint": "9.39.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "3.2.4"
  }
}
