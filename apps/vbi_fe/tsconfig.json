{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "emitDeclarationOnly": false,
    "composite": false,

    /* modules */
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,

    /* type checking */
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "paths": {
      "src/*": ["./src/*"],
      "@visactor/headless-bi-provider": ["../vbi_provider/src/index.ts"],
      "@visactor/headless-bi-provider/*": ["../vbi_provider/src/*"],
      "@visactor/vbi-agent": ["../../packages/vbi-agent/src/index.ts"],
      "@visactor/vbi-agent/*": ["../../packages/vbi-agent/src/*"]
    }
  },
  "references": [
    {
      "path": "../../packages/vseed"
    },
    {
      "path": "../../packages/vbi"
    },
    {
      "path": "../../packages/vbi-agent"
    },
    {
      "path": "../../practices/standard"
    }
  ],
  "include": ["next-env.d.ts", ".next/types/**/*.ts", "src"]
}
