{
  "name": "@visactor/headless-bi-provider",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "homepage": "https://visactor.github.io/VBI",
  "bugs": "https://github.com/VisActor/VBI/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisActor/VBI",
    "directory": "apps/packages/vbi-provider"
  },
  "author": {
    "name": "VisActor",
    "url": "https://www.visactor.io/"
  },
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "rstest",
    "test:update": "rstest --update",
    "test:coverage": "rstest --coverage"
  },
  "dependencies": {
    "@hocuspocus/provider": "3.4.3",
    "@visactor/vbi": "workspace:*",
    "@visactor/vquery": "workspace:*",
    "typebox": "1.1.38",
    "yjs": "13.6.28"
  },
  "devDependencies": {
    "@rstest/core": "0.8.3",
    "@rslib/core": "0.20.3",
    "@types/node": "24.10.1",
    "typescript": "6.0.2"
  },
  "sideEffects": false
}
