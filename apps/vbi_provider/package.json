{
  "name": "@visactor/headless-bi-provider",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "homepage": "https://visactor.github.io/VBI",
  "bugs": "https://github.com/VisActor/VBI/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisActor/VBI",
    "directory": "apps/packages/vbi-provider"
  },
  "author": {
    "name": "VisActor",
    "url": "https://www.visactor.io/"
  },
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hocuspocus/provider": "3.4.3",
    "@visactor/vbi": "workspace:*",
    "yjs": "13.6.28"
  },
  "devDependencies": {
    "@eslint/js": "9.39.0",
    "@rslib/core": "0.20.3",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "3.2.4"
  },
  "sideEffects": false
}
