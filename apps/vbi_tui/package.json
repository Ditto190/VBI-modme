    "@visactor/vbi": "workspace:*",
    "@visactor/vbi-agent": "workspace:*",
    "@visactor/vquery": "workspace:*",
    "dotenv": "17.2.1"
  },
  "devDependencies": {
    "@rslib/core": "0.20.3",
    "@rstest/core": "0.8.3",
    "@types/node": "24.10.1",
    "esbuild": "0.27.2",
    "typescript": "6.0.2"
  }
