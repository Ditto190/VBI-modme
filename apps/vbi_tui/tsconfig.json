{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@visactor/vbi-agent": ["../../packages/vbi-agent/src/index.ts"],
      "src/*": ["../../packages/vbi/src/*"]
    },
    "types": ["node"]
  },
  "references": [
    {
      "path": "../vbi_provider"
    },
    {
      "path": "../../packages/vbi"
    },
    {
      "path": "../../packages/vquery"
    },
    {
      "path": "../../packages/vbi-agent"
    }
  ],
  "include": ["rslib.config.ts", "rstest.config.ts", "src", "tests"]
}
