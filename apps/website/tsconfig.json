{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "emitDeclarationOnly": false,
    "composite": false,
    "types": ["node"],
    "paths": {
      "@components": ["./components"],
      "@components/*": ["./components/*"]
    }
  },
  "references": [
    {
      "path": "../../packages/vseed"
    },
    {
      "path": "../../packages/vquery"
    },
    {
      "path": "../../packages/vbi"
    },
    {
      "path": "../../practices/standard"
    },
    {
      "path": "../../practices/minimalist"
    },
    {
      "path": "../../practices/streamlined"
    },
    {
      "path": "../../practices/professional"
    },
    {
      "path": "../../practices/vbi-react-starter"
    }
  ],
  "include": ["docs", "components", "theme", "rspress.config.ts"],
  "mdx": {
    "checkMdx": true
  }
}
