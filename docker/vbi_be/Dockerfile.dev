# syntax=docker/dockerfile:1.7

FROM node:24.12.0-slim

RUN apt-get update -y && apt-get install -y --no-install-recommends openssl procps && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Enable pnpm
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

# Copy the workspace. .dockerignore is the single source of truth for excluding
# local-only files, which keeps root and package-level config files in sync.
COPY . .
COPY docker/vbi_be/docker-entrypoint.dev.sh /app/docker-entrypoint.dev.sh

# Install all dependencies
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

EXPOSE 3030 9229
EXPOSE 1234

RUN chmod +x /app/docker-entrypoint.dev.sh
ENTRYPOINT ["/app/docker-entrypoint.dev.sh"]
