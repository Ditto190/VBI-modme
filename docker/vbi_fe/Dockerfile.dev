# syntax=docker/dockerfile:1.7

FROM node:24.12.0-slim

WORKDIR /app

# Enable pnpm
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

# Copy the workspace. .dockerignore is the single source of truth for excluding
# local-only files, which keeps root and package-level config files in sync.
COPY . .

# Install all dependencies (including devDependencies)
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

EXPOSE 3000

CMD ["sh", "-lc", "pnpm exec turbo build --filter=@visactor/headless-bi-fe^... && pnpm --filter @visactor/headless-bi-fe exec next dev --hostname 0.0.0.0"]
