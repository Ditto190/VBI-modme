{
  "name": "@visactor/vbi-agent",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "test": "node ../../tools/run-rstest.mjs",
    "test:update": "node ../../tools/run-rstest.mjs --update",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.75.5",
    "@visactor/vbi": "workspace:*",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@rstest/core": "0.8.3",
    "@rslib/core": "0.20.3",
    "@types/node": "24.10.1",
    "typescript": "6.0.2"
  }
}
