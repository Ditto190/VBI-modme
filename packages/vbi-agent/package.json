  },
  "devDependencies": {
    "@eslint/js": "9.39.0",
    "@rstest/core": "0.8.3",
    "@rslib/core": "0.20.3",
    "@types/node": "24.10.1",
    "eslint": "9.39.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  }
