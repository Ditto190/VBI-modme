{
  "$schema": "https://raw.githubusercontent.com/lit/lit/main/packages/localize-tools/config.schema.json",
  "sourceLocale": "en-US",
  "targetLocales": ["zh-CN", "ja-JP", "de-DE", "id-ID", "fr-FR", "ko-KR", "vi-VN"],
  "tsConfig": "./tsconfig.json",
  "output": {
    "mode": "runtime",
    "outputDir": "./src/localization/generated/locales",
    "localeCodesModule": "./src/localization/generated/locale-codes.ts"
  },
  "interchange": {
    "format": "xliff",
    "xliffDir": "./xliff/"
  }
}
