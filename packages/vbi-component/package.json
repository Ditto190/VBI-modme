{
  "name": "@visactor/vbi-component",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "homepage": "https://visactor.github.io/VBI",
  "bugs": "https://github.com/VisActor/VBI/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisActor/VBI",
    "directory": "packages/vbi-component"
  },
  "author": {
    "name": "VisActor",
    "url": "https://www.visactor.io/"
  },
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/vbi-component/vbi-component.esm.js",
  "exports": {
    ".": {
      "import": "./dist/vbi-component/vbi-component.esm.js",
      "require": "./dist/vbi-component/vbi-component.cjs.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    },
    "./*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    }
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "start": "stencil build --dev --watch --serve",
    "build": "stencil build",
    "format": "oxfmt .",
    "lint": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch",
    "generate": "stencil generate",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@stencil/core": "4.43.5",
    "@stencil/store": "2.2.2",
    "@stencil/storybook-plugin": "0.7.0",
    "@stencil/vitest": "1.13.2",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@types/node": "25.9.3",
    "@vitest/browser-playwright": "4.1.9",
    "playwright": "1.61.0",
    "storybook": "10.4.6",
    "vitest": "4.1.9"
  }
}
