{
  "name": "@visactor/vbi-react",
  "version": "0.1.9",
  "private": true,
  "license": "MIT",
  "homepage": "https://visactor.github.io/VBI",
  "bugs": "https://github.com/VisActor/VBI/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisActor/VBI",
    "directory": "packages/vbi-react"
  },
  "author": {
    "name": "VisActor",
    "url": "https://www.visactor.io/"
  },
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "source": "./src/components/index.ts",
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.cjs"
    },
    "./components.css": {
      "source": "./src/components/entry.css",
      "default": "./dist/components.css"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "build:api": "node ./scripts/build-api.mjs",
    "build:docs": "node ./scripts/build-docs.mjs",
    "build:examples": "node ./scripts/build-examples.mjs",
    "dev": "rslib build --watch --no-clean",
    "format": "oxfmt .",
    "g": "pnpm run build:api && pnpm run build:examples && pnpm run build:docs && pnpm run format",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@visactor/vbi": "workspace:*",
    "react": ">=18"
  },
  "devDependencies": {
    "@rslib/core": "0.20.3",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@visactor/vbi": "workspace:*",
    "@visactor/vseed": "workspace:*",
    "@vitest/coverage-v8": "3.2.4",
    "happy-dom": "20.4.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "6.0.2",
    "vitest": "3.2.4"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
