{
  "name": "@visactor/vdash",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "rslib build --watch --no-clean",
    "build": "rslib build",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "test": "rstest",
    "test:update": "rstest --update",
    "test:coverage": "rstest --coverage",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "gridstack": "12.6.0",
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "@rstest/core": "0.8.3",
    "@rslib/core": "0.20.3",
    "@types/node": "24.10.1",
    "typescript": "6.0.2"
  }
}
