{
  "name": "@visactor/vquery",
  "version": "0.5.3",
  "license": "MIT",
  "homepage": "https://visactor.github.io/VBI",
  "bugs": "https://github.com/VisActor/VBI/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisActor/VBI",
    "directory": "packages/vquery"
  },
  "author": {
    "name": "VisActor",
    "url": "https://www.visactor.io/"
  },
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "source": "./src/node.ts",
        "types": "./dist/node/esm/node.d.ts",
        "import": "./dist/node/esm/node.js",
        "require": "./dist/node/cjs/node.cjs"
      },
      "browser": {
        "source": "./src/browser.ts",
        "types": "./dist/browser/esm/browser.d.ts",
        "import": "./dist/browser/esm/browser.js"
      },
      "default": {
        "source": "./src/browser.ts",
        "types": "./dist/browser/esm/browser.d.ts",
        "import": "./dist/browser/esm/browser.js"
      }
    }
  },
  "main": "./dist/node/cjs/node.cjs",
  "types": "./dist/node/esm/node.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "build:test": "node scripts/build-tests.js",
    "build:docs": "node scripts/build-examples.js",
    "g": "pnpm run build:test && pnpm run build:docs && pnpm run test:update",
    "dev": "rslib build --watch --no-clean",
    "lint": "oxlint .",
    "test": "rstest",
    "format": "oxfmt .",
    "test:update": "rstest --update",
    "test:coverage": "rstest --coverage && node scripts/build-coverage-badge.mjs && open ./coverage/index.html",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.30.0",
    "kysely": "0.27.6",
    "web-worker": "1.5.0"
  },
  "devDependencies": {
    "@rslib/core": "0.20.3",
    "@rstest/core": "0.8.3",
    "@types/node": "24.10.1",
    "@rstest/coverage-istanbul": "0.2.1",
    "typescript": "6.0.2"
  }
}
