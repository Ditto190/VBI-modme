{
  "name": "annotationDifferenceLineStackTotal",
  "description": "A stacked column chart with a difference line between two stack totals.",
  "vseed": {
    "chartType": "column",
    "dataset": [
      { "year": "1930", "autocracies": 129, "democracies": 23 },
      { "year": "1940", "autocracies": 133, "democracies": 14 },
      { "year": "1950", "autocracies": 130, "democracies": 26 },
      { "year": "2000", "autocracies": 89, "democracies": 87 }
    ],
    "annotationDifferenceLine": {
      "start": {
        "selector": { "year": "1930" }
      },
      "end": {
        "selector": { "year": "2000" }
      },
      "differenceType": "absolute",
      "textFontSize": 14,
      "textColor": "#ffffff",
      "textBackgroundColor": "#212121",
      "lineColor": "#212121"
    },
    "dimensions": [{ "id": "year", "alias": "年份", "encoding": "xAxis" }],
    "measures": [
      { "id": "autocracies", "alias": "Autocracies", "encoding": "yAxis" },
      { "id": "democracies", "alias": "Democracies", "encoding": "yAxis" }
    ]
  }
}
