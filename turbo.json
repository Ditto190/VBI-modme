{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["pnpm-lock.yaml", "pnpm-workspace.yaml", ".oxlintrc.json", ".env.example"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "website#build": {
      "dependsOn": ["^build"],
      "outputs": ["doc_build/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:update": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
